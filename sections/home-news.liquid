<section class="pp-home-news">
  <div class="pp-home-social" aria-label="Social links">
    <a href="{{ settings.instagram_url | default: '#' }}" aria-label="Instagram"><svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"></rect><circle cx="12" cy="12" r="4"></circle><circle cx="17.5" cy="6.5" r="1.2"></circle></svg></a>
    <a href="{{ settings.facebook_url | default: '#' }}" aria-label="Facebook"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14.6 8.4V6.7c0-.8.4-1.2 1.3-1.2h1.5V3h-2.2c-2.6 0-4.1 1.5-4.1 4v1.4H8.6v2.8h2.5V21h3.5v-9.8h2.6l.4-2.8h-3z"></path></svg></a>
    <a href="{{ settings.tiktok_url | default: '#' }}" aria-label="TikTok"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15.6 3c.4 2.4 1.8 3.9 4.1 4.1v3.2c-1.5.1-2.8-.4-4-1.2v5.8c0 3.5-2.2 6.1-5.8 6.1-3.1 0-5.4-2.1-5.4-5.1 0-3.3 2.7-5.3 5.9-5.2.3 0 .6 0 .9.1V14c-.3-.1-.6-.1-.9-.1-1.5 0-2.5.8-2.5 2 0 1.1.9 1.9 2.1 1.9 1.4 0 2.2-.8 2.2-2.5V3h3.4z"></path></svg></a>
  </div>

  <div class="pp-home-news-inner">
    <div class="pp-home-ticker" aria-label="Current updates"><span>Trailer news</span><span>New drops</span><span>Market pop-ups</span><span>Restock alerts</span></div>
    <div class="pp-home-motion-line" aria-hidden="true"><div><span>Trailer news</span><span>New drops</span><span>Pop-up notes</span><span>Restock alerts</span><span>Trailer news</span><span>New drops</span><span>Pop-up notes</span><span>Restock alerts</span></div></div>
    <div class="pp-home-intro"><div class="pp-heading-eyebrow">{{ section.settings.eyebrow }}</div><h1>{{ section.settings.heading }}</h1>{% if section.settings.body != blank %}<p>{{ section.settings.body }}</p>{% endif %}</div>

    <div id="news" class="pp-home-updates">
      {% for block in section.blocks %}
        <article class="pp-home-update" {{ block.shopify_attributes }}><div class="pp-home-update-meta"><span>{{ block.settings.label }}</span><span>{{ block.settings.date }}</span></div><h2>{{ block.settings.title }}</h2>{% if block.settings.body != blank %}<div class="pp-home-update-copy">{{ block.settings.body }}</div>{% endif %}{% if block.settings.link_label != blank and block.settings.link != blank %}<a href="{{ block.settings.link }}">{{ block.settings.link_label }}</a>{% endif %}</article>
      {% endfor %}
    </div>

    {% if section.settings.show_signup %}
      <div class="pp-home-signup-wrap">{% form 'customer', class: 'pp-home-signup' %}<input type="hidden" name="contact[tags]" value="newsletter"><label class="pp-heading-eyebrow" for="HomeEmail-{{ section.id }}">Drop alerts</label><div class="pp-home-signup-row"><input id="HomeEmail-{{ section.id }}" type="email" name="contact[email]" placeholder="Email address" required><button type="submit">Join</button></div>{% endform %}</div>
    {% endif %}

    <div id="contact" class="pp-home-contact"><div><div class="pp-heading-eyebrow">Contact</div><h2>Questions, pop-ups, pickups, or collabs?</h2><p>Send a note here. This keeps contact available without needing a separate Shopify page.</p></div>{% form 'contact', class: 'pp-home-contact-form' %}<div class="pp-home-contact-grid"><input type="text" name="contact[name]" placeholder="Name"><input type="email" name="contact[email]" placeholder="Email" required></div><input type="text" name="contact[subject]" placeholder="Subject"><textarea name="contact[body]" rows="5" placeholder="Message"></textarea><button type="submit">Send message</button>{% endform %}</div>
  </div>
</section>

{% schema %}
{
  "name": "Home news",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Pocket Parade" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Trailer updates, surprise drops, and pop-up notes." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "The front door for what is happening now: where the trailer is headed, what just landed, and what is almost sold out." },
    { "type": "checkbox", "id": "show_signup", "label": "Show email signup", "default": true }
  ],
  "blocks": [
    { "type": "update", "name": "Update", "settings": [
      { "type": "text", "id": "label", "label": "Label", "default": "Trailer" },
      { "type": "text", "id": "date", "label": "Date", "default": "This week" },
      { "type": "text", "id": "title", "label": "Title", "default": "Catch the trailer at the next local stop." },
      { "type": "textarea", "id": "body", "label": "Body", "default": "Post the location, pickup window, featured products, and any weather or schedule notes right here." },
      { "type": "text", "id": "link_label", "label": "Link label", "default": "View details" },
      { "type": "url", "id": "link", "label": "Link" }
    ] }
  ],
  "max_blocks": 8,
  "presets": [{ "name": "Home news", "blocks": [{ "type": "update" }, { "type": "update" }] }]
}
{% endschema %}
