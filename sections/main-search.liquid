<section class="pp-section"><div class="pp-container"><div class="pp-card pp-search-card"><div class="pp-heading-eyebrow">Search</div><h1 class="pp-heading-lg">Find your next favorite</h1><form action="{{ routes.search_url }}" method="get" role="search" class="pp-search-form"><input class="pp-input" type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products, pages, and collections"><button class="pp-button" type="submit">Search</button></form></div>{% if search.performed %}{% paginate search.results by 12 %}{% if search.results_count > 0 %}<div class="pp-shop-toolbar"><span>{{ search.results_count }} result{% unless search.results_count == 1 %}s{% endunless %}</span></div><div class="pp-products">{% for item in search.results %}{% if item.object_type == 'product' %}{% render 'product-card', product: item %}{% else %}<a class="pp-product-card" href="{{ item.url }}"><div class="pp-heading-eyebrow">{{ item.object_type }}</div><h3>{{ item.title }}</h3></a>{% endif %}{% endfor %}</div>{% else %}<div class="pp-card pp-empty-state"><div class="pp-heading-eyebrow">No results</div><h2 class="pp-heading-lg">Try another search.</h2><a class="pp-button" href="/collections/all">Browse products</a></div>{% endif %}{% endpaginate %}{% endif %}</div></section>
{% schema %}
{"name":"Main search","settings":[]}
{% endschema %}
