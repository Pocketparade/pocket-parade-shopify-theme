<section class="pp-shop-page"><div class="pp-container"><div class="pp-shop-hero"><div><div class="pp-heading-eyebrow">Collections</div><h1>Shop by story.</h1><p>Browse all published collections in one place.</p></div><div class="pp-shop-hero-actions"><a href="/collections/all">Shop all</a><a href="/#news">News</a></div></div>{% paginate collections by 12 %}<div class="pp-products" style="margin-top:24px;">{% for collection in collections %}<a class="pp-product-card" href="{{ collection.url }}"><div class="pp-product-media">{% if collection.featured_image %}{{ collection.featured_image | image_url: width: 700 | image_tag: loading: 'lazy', widths: '320,520,700', style: 'width:100%; height:100%; object-fit:cover;' }}{% elsif collection.products.first.featured_image %}{{ collection.products.first.featured_image | image_url: width: 700 | image_tag: loading: 'lazy', widths: '320,520,700', style: 'width:100%; height:100%; object-fit:cover;' }}{% endif %}</div><div class="pp-product-info"><div class="pp-badge">{{ collection.products_count }} item{% unless collection.products_count == 1 %}s{% endunless %}</div><h3>{{ collection.title }}</h3>{% if collection.description != blank %}<div class="pp-muted-small">{{ collection.description | strip_html | truncate: 90 }}</div>{% endif %}</div></a>{% else %}<div class="pp-card pp-empty-state"><div class="pp-heading-eyebrow">Collections</div><h2 class="pp-heading-lg">No collections are published yet.</h2></div>{% endfor %}</div>{% endpaginate %}</div></section>
{% schema %}
{"name":"Main list collections","settings":[]}
{% endschema %}
